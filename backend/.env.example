# For AWS RDS with TLS, place global-bundle.pem under backend/certs/ (see README).
# sslrootcert=./certs/global-bundle.pem is resolved to an absolute path at runtime.
DATABASE_URL=postgresql://user:pass@your-rds.region.rds.amazonaws.com:5432/melopark?sslmode=verify-full&sslrootcert=./certs/global-bundle.pem
ENVIRONMENT=development
