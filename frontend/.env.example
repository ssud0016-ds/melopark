# Optional: absolute backend URL for production builds (e.g. https://api.example.com).
# Leave empty in development — Vite proxies /api to http://127.0.0.1:8000 (see vite.config.js).
#
# Production (Vercel): set this to your deployed API origin so the client calls that host.
# CSP in vercel.json allows connect-src https: — ensure CORS on the API allows your site origin.
VITE_API_URL=
